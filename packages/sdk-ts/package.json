{
  "name": "@liens-fi/sdk",
  "version": "0.1.0",
  "description": "Lien TypeScript SDK — compose hooks, simulate lifecycle events, send transactions to the on-chain executor.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/web3.js": "^1.95.4",
    "@liens-fi/marginfi-adapter": "workspace:*",
    "@liens-fi/kamino-adapter": "workspace:*",
    "@liens-fi/solend-adapter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
