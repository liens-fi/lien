{
  "name": "lien-cli",
  "version": "0.1.0",
  "description": "Lien command-line tools — create, simulate, and deploy lending hooks on Solana.",
  "type": "module",
  "bin": {
    "lien": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "templates"],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "tsx src/bin.ts"
  },
  "dependencies": {
    "@liens/sdk": "workspace:*",
    "@solana/web3.js": "^1.95.4",
    "commander": "^13.0.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
